      <button class="btn btn-purple" onclick="replayAnim()">▶ Xem lại</button>
      <button class="btn btn-blue" onclick="loopAnim()">🔁 Lặp</button>
      <button class="btn btn-green" onclick="stopAnim()">⏹ Dừng</button>
    </div>
    <button class="modal-close" onclick="closeModal('modal-anim')">Đóng</button>
  </div>
</div>

<!-- MODAL: TẬP VIẾT -->
<div class="modal-overlay" id="modal-quiz" onclick="closeModal('modal-quiz')">
  <div class="modal-box" onclick="event.stopPropagation()">
    <h3>✍️ Tập viết chữ 人</h3>
    <div id="quiz-container"></div>
    <div class="quiz-status" id="quiz-status">Dùng chuột hoặc ngón tay vẽ theo nét mờ</div>
    <button class="modal-close" onclick="closeModal('modal-quiz')">Đóng</button>
  </div>
</div>

<script>
const CHAR = "人";
let writerAnim = null;
let writerQuiz = null;
let animInited = false;
let quizInited = false;

// Phát âm
function speakChar() { speak(CHAR); }
function speak(text) {
  if (!window.speechSynthesis) return;
  window.speechSynthesis.cancel();
  const u = new SpeechSynthesisUtterance(text);
  u.lang = 'zh-CN'; u.rate = 0.8;
  window.speechSynthesis.speak(u);
}

// Mở/đóng modal
function closeModal(id) {
  document.getElementById(id).classList.remove('open');
  if (writerAnim) writerAnim.stopAnimation();
}

// ANIMATION
function showAnim() {
  document.getElementById('modal-anim').classList.add('open');
  if (!animInited) {
    writerAnim = HanziWriter.create('anim-container', CHAR, {
      width: 200, height: 200, padding: 16,
      showOutline: true,
      strokeColor: '#3949ab',
      outlineColor: '#c5cae9',
      strokeAnimationSpeed: 1,
      delayBetweenStrokes: 400,
    });
    animInited = true;
  }
  setTimeout(() => writerAnim.animateCharacter(), 300);
}
function replayAnim() { if (writerAnim) writerAnim.animateCharacter(); }
function loopAnim() { if (writerAnim) writerAnim.loopCharacterAnimation(); }
function stopAnim() { if (writerAnim) { writerAnim.stopAnimation(); writerAnim.showCharacter(); } }

// QUIZ
function showQuiz() {
  document.getElementById('modal-quiz').classList.add('open');
  if (!quizInited) {
    writerQuiz = HanziWriter.create('quiz-container', CHAR, {
      width: 220, height: 220, padding: 16,
      showCharacter: false, showOutline: true,
      strokeColor: '#e53935',
      outlineColor: '#c5cae9',
      drawingColor: '#3949ab',
      highlightOnComplete: true,
      highlightColor: '#43a047',
    });
    quizInited = true;
    startQuiz();
  }
}
function startQuiz() {
  if (!writerQuiz) return;
  setQS('Dùng chuột hoặc ngón tay vẽ theo nét mờ', '');
  writerQuiz.quiz({
    onMistake: () => setQS('Sai nét! Thử lại ↗', 'err'),
    onCorrectStroke: () => setQS('✓ Đúng! Tiếp tục...', 'ok'),
    onComplete: (s) => {
      setQS('🎉 Hoàn thành! ' + (s.totalMistakes === 0 ? 'Hoàn hảo!' : s.totalMistakes + ' lỗi'), 'ok');
      setTimeout(startQuiz, 2000);
    }
  });
}
function setQS(msg, cls) {
  const el = document.getElementById('quiz-status');
  el.textContent = msg;
  el.className = 'quiz-status' + (cls ? ' ' + cls : '');
}

// Init ô chữ nhỏ trong info-card (hiển thị tĩnh)
window.addEventListener('DOMContentLoaded', () => {
  HanziWriter.create('hanzi-writer-target', CHAR, {
    width: 110, height: 110, padding: 8,
    showOutline: true,
    strokeColor: '#3949ab',
    outlineColor: '#c5cae9',
    showCharacter: true,
    delayBetweenStrokes: 300,
  });
});
</script>
</body>
</html>
